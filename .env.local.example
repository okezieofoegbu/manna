# Manna — environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and must NEVER be committed.
#
# After editing .env.local you must RESTART the dev server — Next.js reads
# environment variables at startup, not live.

# --- Supabase (browser-safe — required since v0.1.0) ---
# Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only keys (required for v0.1.2 — the devotional engine) ---
# NEVER prefix these with NEXT_PUBLIC_. They are used only inside API routes
# and must never reach the browser. See PITFALLS.md Section 2.

# Supabase service-role key — server-side writes to devotional_days.
# Supabase project: Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — generates the daily reflection.
ANTHROPIC_API_KEY=

# API.Bible key (American Bible Society) — the passage text.
BIBLE_API_KEY=

# --- Optional (sensible defaults apply if left blank) ---
# The model used for the reflection. Default: claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# The owner's time zone, used to compute "today". Default: America/New_York.
# MANNA_TIMEZONE=America/New_York

# --- Not needed yet — later versions ---
# Zoho Mail API (v0.1.3 — the Transworld inbox)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=

# Google Calendar API (v0.1.4 — the schedule action)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
