# Manna — environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and must NEVER be committed.

# --- Supabase (required for v0.1.0) ---
# Found in your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- The following are NOT needed for v0.1.0 ---
# They are listed here so you know what is coming in later versions.
# Leave them blank for now.

# Anthropic API (v0.1.2 — devotional + email synthesis)
# ANTHROPIC_API_KEY=

# Zoho Mail API (v0.1.3 — Transworld inbox)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=

# Bible text API (v0.1.2 — passage text)
# ESV_API_KEY=

# Google Calendar API (v0.1.4 — schedule action)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
