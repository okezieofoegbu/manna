// lib/share-image.jsx
//
// The JSX component @vercel/og renders into the share PNG. v0.1.8.8.
//
// Design — based on the v0.1.8.2 mockup, refined through:
//   v0.1.8.3   — inline *...* emphasis works (word-by-word flex spans)
//   v0.1.8.3.1 — image height 2000, footer fits, justify not honored
//   v0.1.8.3.2 — nested-span justify attempt, satori 500, rolled back
//   v0.1.8.6   — fonts +40%, height 2000 → 2400
//   v0.1.8.7   — fonts +10% more, height 2400 → 2700
//   v0.1.8.8   — height 2700 → 3300 only (no font / prompt change)
//
// v0.1.8.7 fonts were confirmed correct on iPhone (no further bump
// wanted). The remaining issue was the canvas — today's 340-word
// Galatians 2:20 regen overflowed at 2700, and tomorrow's v1.3.2
// reflections target 350-450 words. 3300 gives ~600px of additional
// body area, comfortably absorbing the upper end of the new word
// target with margin to spare.
//
// 1200x3300 portrait, warm gradient cream→deeper-cream, centered
// header, date and theme line, passage reference, centered passage
// italic, small centered rule, reflection body with bold-italic
// emphasis on *...* segments flowing inline word-by-word, footer.
//
// v0.1.8.7 → v0.1.8.8 changes:
//
// SINGLE change: canvas height 2700 → 3300.
//
// v0.1.8.7 fonts confirmed correct ("size is perfect now"). The
// remaining overflow on today's 340-word Galatians 2:20 regen at the
// 2700 canvas told us the canvas was undersized for the new v1.3.2
// word target. 2700 → 3300 gives ~600px of additional body area:
//   - Today's 340-word regen fits with comfortable margin.
//   - Tomorrow's v1.3.2 reflections (350-450 word target) fit at
//     the upper end of the range with margin to spare.
//   - Future reflections that lean shorter sit in a slightly tall
//     canvas; not visually disruptive — the gradient continues, the
//     footer is pinned absolute to the bottom.
//
// No font changes. No vertical-rhythm changes. Just the number.
//
// All v0.1.8.3 satori workarounds remain:
//   - Word-by-word flex spans for inline emphasis (confirmed working).
//   - flexShrink: 0 on major blocks (prevents satori compression).
//   - Left-aligned body (justify isn't reachable in satori for this
//     design, per PITFALLS §21).
//
// Satori CSS rules followed throughout:
// - Every <div> with multiple children has explicit display:'flex'.
// - Inline styles only, no className.
// - Width and height required on root.

import React from 'react';

const COLORS = {
  ink: '#2C241C',
  inkSoft: '#6E5F50',
  amber: '#B5842F',
  creamTop: '#FDF8EE',
  creamBottom: '#F4E6CD',
};

// Parse *...* segments into a list of { text, emphasis } runs.
function parseRuns(text) {
  const runs = [];
  const re = /\*([^*]+)\*/g;
  let last = 0;
  let m;
  while ((m = re.exec(text)) !== null) {
    if (m.index > last) {
      runs.push({ text: text.slice(last, m.index), emphasis: false });
    }
    runs.push({ text: m[1], emphasis: true });
    last = m.index + m[0].length;
  }
  if (last < text.length) {
    runs.push({ text: text.slice(last), emphasis: false });
  }
  if (runs.length === 0) {
    runs.push({ text, emphasis: false });
  }
  return runs;
}

// Split reflection into paragraphs (blank-line separated).
function splitParagraphs(reflection) {
  if (!reflection) return [];
  return reflection
    .split(/\n\s*\n/)
    .map((p) => p.trim())
    .filter(Boolean);
}

// Strip API.Bible verse-number brackets [1] [2] etc. from passage text
// for the share image.
function stripVerseBrackets(text) {
  if (!text) return '';
  return String(text).replace(/\[\d+\]\s*/g, '').replace(/\s+/g, ' ').trim();
}

// Expand runs into word-tokens for satori inline flow.
function tokenizeRunsToWords(runs) {
  const words = [];
  runs.forEach((run, runIdx) => {
    const tokens = run.text.match(/\S+\s*/g) || [];
    tokens.forEach((token, tokenIdx) => {
      words.push({
        text: token,
        emphasis: run.emphasis,
        key: `${runIdx}-${tokenIdx}`,
      });
    });
  });
  return words;
}

export function ShareImage({
  longDate,
  themeName,
  morningCount,
  passageReference,
  passageText,
  reflection,
}) {
  const paragraphs = splitParagraphs(reflection);
  const passageClean = stripVerseBrackets(passageText);
  const themeLineText =
    morningCount > 0 ? `${themeName} — morning ${morningCount}` : themeName;

  const dateThemeLine = `${longDate} · ${themeLineText}`;
  const passageRefUpper = (passageReference || '').toUpperCase();

  return (
    <div
      style={{
        width: 1200,
        height: 3300,
        display: 'flex',
        flexDirection: 'column',
        background: `linear-gradient(180deg, ${COLORS.creamTop} 0%, ${COLORS.creamBottom} 100%)`,
        fontFamily: 'Lora',
        color: COLORS.ink,
        padding: '110px 110px',
        position: 'relative',
      }}
    >
      {/* Soft top glow — faint radial gradient suggesting dawn light. */}
      <div
        style={{
          position: 'absolute',
          top: -200,
          left: 0,
          right: 0,
          height: 500,
          background:
            'radial-gradient(ellipse at center top, rgba(255, 235, 195, 0.4) 0%, rgba(255, 235, 195, 0) 70%)',
          display: 'flex',
        }}
      />

      {/* Header: Manna · Word before work · amber rule (3 children) */}
      <div
        style={{
          display: 'flex',
          flexDirection: 'column',
          alignItems: 'center',
          marginBottom: 56,
          flexShrink: 0,
        }}
      >
        <div style={{ fontSize: 60, color: COLORS.ink, marginBottom: 10, display: 'flex' }}>
          Manna
        </div>
        <div
          style={{
            fontSize: 34,
            color: COLORS.inkSoft,
            fontStyle: 'italic',
            marginBottom: 26,
            display: 'flex',
          }}
        >
          Word before work.
        </div>
        <div
          style={{
            width: 100,
            height: 2,
            backgroundColor: COLORS.amber,
            display: 'flex',
          }}
        />
      </div>

      {/* Date and theme line — single text child */}
      <div
        style={{
          display: 'flex',
          justifyContent: 'center',
          fontSize: 34,
          color: COLORS.inkSoft,
          marginBottom: 68,
          flexShrink: 0,
        }}
      >
        {dateThemeLine}
      </div>

      {/* Passage reference — single text child */}
      <div
        style={{
          display: 'flex',
          justifyContent: 'center',
          fontSize: 42,
          color: COLORS.amber,
          letterSpacing: 3,
          marginBottom: 56,
          flexShrink: 0,
        }}
      >
        {passageRefUpper}
      </div>

      {/* Passage text — single text child */}
      <div
        style={{
          display: 'flex',
          alignSelf: 'center',
          textAlign: 'center',
          fontStyle: 'italic',
          fontSize: 52,
          lineHeight: 1.4,
          maxWidth: 950,
          marginBottom: 96,
          color: COLORS.ink,
          flexShrink: 0,
        }}
      >
        {passageClean}
      </div>

      {/* Small centered rule */}
      <div
        style={{
          display: 'flex',
          alignSelf: 'center',
          width: 36,
          height: 1,
          backgroundColor: COLORS.amber,
          marginBottom: 56,
          flexShrink: 0,
        }}
      />

      {/* Reflection body — column of paragraph blocks with word-spans. */}
      <div
        style={{
          display: 'flex',
          flexDirection: 'column',
          fontSize: 46,
          lineHeight: 1.5,
          color: COLORS.ink,
          flexShrink: 0,
        }}
      >
        {paragraphs.map((para, i) => {
          const runs = parseRuns(para);
          const words = tokenizeRunsToWords(runs);
          return (
            <div
              key={i}
              style={{
                display: 'flex',
                flexWrap: 'wrap',
                marginBottom: 38,
                flexShrink: 0,
              }}
            >
              {words.map((w) => (
                <span
                  key={w.key}
                  style={{
                    fontStyle: w.emphasis ? 'italic' : 'normal',
                    fontWeight: w.emphasis ? 700 : 400,
                    whiteSpace: 'pre',
                  }}
                >
                  {w.text}
                </span>
              ))}
            </div>
          );
        })}
      </div>

      {/* Footer pinned at the bottom — single text child */}
      <div
        style={{
          position: 'absolute',
          bottom: 80,
          left: 0,
          right: 0,
          display: 'flex',
          justifyContent: 'center',
          fontSize: 28,
          fontStyle: 'italic',
          color: COLORS.inkSoft,
        }}
      >
        manna · a private morning page
      </div>
    </div>
  );
}
