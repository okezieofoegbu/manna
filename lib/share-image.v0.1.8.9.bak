// lib/share-image.jsx
//
// The JSX component @vercel/og renders into the share PNG. v0.1.8.9.
//
// Design — based on the v0.1.8.2 mockup, refined through:
//   v0.1.8.3   — inline *...* emphasis works (word-by-word flex spans)
//   v0.1.8.3.1 — image height 2000, footer fits, justify not honored
//   v0.1.8.3.2 — nested-span justify attempt, satori 500, rolled back
//   v0.1.8.6   — fonts +40%, height 2000 → 2400
//   v0.1.8.7   — fonts +10% more, height 2400 → 2700
//   v0.1.8.8   — height 2700 → 3300 (still 1200 wide)
//   v0.1.8.9   — canvas 1200×3300 → 1400×3700, passage maxWidth 1100
//
// v0.1.8.9 reasoning:
// At v0.1.8.8 the canvas was 1200×3300 (aspect ratio 1:2.75). When
// iOS scales this PNG to fit phone width (~400px in inline display),
// the entire canvas — including every text run — gets proportionally
// shrunk. The taller the aspect ratio, the more each PNG pixel is
// visually compressed. The result: text felt smaller on phone than at
// v0.1.8.7's 1:2.25 aspect ratio, even though the PNG font sizes were
// unchanged.
//
// v0.1.8.9 fixes this by extending width as well as height:
//   - Canvas:    1200×3300 → 1400×3700 (aspect ratio 1:2.64, closer
//                to v0.1.8.7's 1:2.25)
//   - Passage maxWidth: 950 → 1100, so the centered passage block
//                stays proportional to the wider canvas instead of
//                looking pinched
//   - Fonts unchanged. The width bump is doing the visual work.
//
// Net effect: ~30% more total body area than v0.1.8.8, the v0.1.8.7
// "size is perfect" reading size is preserved when scaled to phone
// width, and 350-450 word reflections fit comfortably.
//
// 1400x3700 portrait, warm gradient cream→deeper-cream, centered
// header, date and theme line, passage reference, centered passage
// italic, small centered rule, reflection body with bold-italic
// emphasis on *...* segments flowing inline word-by-word, footer.
//
// v0.1.8.8 → v0.1.8.9 changes:
//
// Three coordinated changes addressing the on-phone aspect-ratio
// problem discovered at v0.1.8.8:
//
// 1. Canvas: 1200×3300 → 1400×3700
//    Width grows +17%, height grows +12%. Aspect ratio improves
//    from 1:2.75 back toward v0.1.8.7's 1:2.25.
//
// 2. Passage maxWidth: 950 → 1100
//    Keeps the centered passage italic proportional to the wider
//    canvas. At 950 in a 1400-wide canvas the passage would look
//    pinched, with too much whitespace on either side.
//
// 3. Fonts UNCHANGED. v0.1.8.7 sizes are confirmed correct; the
//    width bump is doing the visual work of restoring the v0.1.8.7
//    reading size on phone.
//
// Vertical rhythm unchanged. Padding unchanged. Everything else from
// v0.1.8.7/v0.1.8.8 unchanged.
//
// All v0.1.8.3 satori workarounds remain:
//   - Word-by-word flex spans for inline emphasis (confirmed working).
//   - flexShrink: 0 on major blocks (prevents satori compression).
//   - Left-aligned body (justify isn't reachable in satori for this
//     design, per PITFALLS §21).
//
// Satori CSS rules followed throughout:
// - Every <div> with multiple children has explicit display:'flex'.
// - Inline styles only, no className.
// - Width and height required on root.

import React from 'react';

const COLORS = {
  ink: '#2C241C',
  inkSoft: '#6E5F50',
  amber: '#B5842F',
  creamTop: '#FDF8EE',
  creamBottom: '#F4E6CD',
};

// Parse *...* segments into a list of { text, emphasis } runs.
function parseRuns(text) {
  const runs = [];
  const re = /\*([^*]+)\*/g;
  let last = 0;
  let m;
  while ((m = re.exec(text)) !== null) {
    if (m.index > last) {
      runs.push({ text: text.slice(last, m.index), emphasis: false });
    }
    runs.push({ text: m[1], emphasis: true });
    last = m.index + m[0].length;
  }
  if (last < text.length) {
    runs.push({ text: text.slice(last), emphasis: false });
  }
  if (runs.length === 0) {
    runs.push({ text, emphasis: false });
  }
  return runs;
}

// Split reflection into paragraphs (blank-line separated).
function splitParagraphs(reflection) {
  if (!reflection) return [];
  return reflection
    .split(/\n\s*\n/)
    .map((p) => p.trim())
    .filter(Boolean);
}

// Strip API.Bible verse-number brackets [1] [2] etc. from passage text
// for the share image.
function stripVerseBrackets(text) {
  if (!text) return '';
  return String(text).replace(/\[\d+\]\s*/g, '').replace(/\s+/g, ' ').trim();
}

// Expand runs into word-tokens for satori inline flow.
function tokenizeRunsToWords(runs) {
  const words = [];
  runs.forEach((run, runIdx) => {
    const tokens = run.text.match(/\S+\s*/g) || [];
    tokens.forEach((token, tokenIdx) => {
      words.push({
        text: token,
        emphasis: run.emphasis,
        key: `${runIdx}-${tokenIdx}`,
      });
    });
  });
  return words;
}

export function ShareImage({
  longDate,
  themeName,
  morningCount,
  passageReference,
  passageText,
  reflection,
}) {
  const paragraphs = splitParagraphs(reflection);
  const passageClean = stripVerseBrackets(passageText);
  const themeLineText =
    morningCount > 0 ? `${themeName} — morning ${morningCount}` : themeName;

  const dateThemeLine = `${longDate} · ${themeLineText}`;
  const passageRefUpper = (passageReference || '').toUpperCase();

  return (
    <div
      style={{
        width: 1400,
        height: 3700,
        display: 'flex',
        flexDirection: 'column',
        background: `linear-gradient(180deg, ${COLORS.creamTop} 0%, ${COLORS.creamBottom} 100%)`,
        fontFamily: 'Lora',
        color: COLORS.ink,
        padding: '110px 110px',
        position: 'relative',
      }}
    >
      {/* Soft top glow — faint radial gradient suggesting dawn light. */}
      <div
        style={{
          position: 'absolute',
          top: -200,
          left: 0,
          right: 0,
          height: 500,
          background:
            'radial-gradient(ellipse at center top, rgba(255, 235, 195, 0.4) 0%, rgba(255, 235, 195, 0) 70%)',
          display: 'flex',
        }}
      />

      {/* Header: Manna · Word before work · amber rule (3 children) */}
      <div
        style={{
          display: 'flex',
          flexDirection: 'column',
          alignItems: 'center',
          marginBottom: 56,
          flexShrink: 0,
        }}
      >
        <div style={{ fontSize: 60, color: COLORS.ink, marginBottom: 10, display: 'flex' }}>
          Manna
        </div>
        <div
          style={{
            fontSize: 34,
            color: COLORS.inkSoft,
            fontStyle: 'italic',
            marginBottom: 26,
            display: 'flex',
          }}
        >
          Word before work.
        </div>
        <div
          style={{
            width: 100,
            height: 2,
            backgroundColor: COLORS.amber,
            display: 'flex',
          }}
        />
      </div>

      {/* Date and theme line — single text child */}
      <div
        style={{
          display: 'flex',
          justifyContent: 'center',
          fontSize: 34,
          color: COLORS.inkSoft,
          marginBottom: 68,
          flexShrink: 0,
        }}
      >
        {dateThemeLine}
      </div>

      {/* Passage reference — single text child */}
      <div
        style={{
          display: 'flex',
          justifyContent: 'center',
          fontSize: 42,
          color: COLORS.amber,
          letterSpacing: 3,
          marginBottom: 56,
          flexShrink: 0,
        }}
      >
        {passageRefUpper}
      </div>

      {/* Passage text — single text child */}
      <div
        style={{
          display: 'flex',
          alignSelf: 'center',
          textAlign: 'center',
          fontStyle: 'italic',
          fontSize: 52,
          lineHeight: 1.4,
          maxWidth: 1100,
          marginBottom: 96,
          color: COLORS.ink,
          flexShrink: 0,
        }}
      >
        {passageClean}
      </div>

      {/* Small centered rule */}
      <div
        style={{
          display: 'flex',
          alignSelf: 'center',
          width: 36,
          height: 1,
          backgroundColor: COLORS.amber,
          marginBottom: 56,
          flexShrink: 0,
        }}
      />

      {/* Reflection body — column of paragraph blocks with word-spans. */}
      <div
        style={{
          display: 'flex',
          flexDirection: 'column',
          fontSize: 46,
          lineHeight: 1.5,
          color: COLORS.ink,
          flexShrink: 0,
        }}
      >
        {paragraphs.map((para, i) => {
          const runs = parseRuns(para);
          const words = tokenizeRunsToWords(runs);
          return (
            <div
              key={i}
              style={{
                display: 'flex',
                flexWrap: 'wrap',
                marginBottom: 38,
                flexShrink: 0,
              }}
            >
              {words.map((w) => (
                <span
                  key={w.key}
                  style={{
                    fontStyle: w.emphasis ? 'italic' : 'normal',
                    fontWeight: w.emphasis ? 700 : 400,
                    whiteSpace: 'pre',
                  }}
                >
                  {w.text}
                </span>
              ))}
            </div>
          );
        })}
      </div>

      {/* Footer pinned at the bottom — single text child */}
      <div
        style={{
          position: 'absolute',
          bottom: 80,
          left: 0,
          right: 0,
          display: 'flex',
          justifyContent: 'center',
          fontSize: 28,
          fontStyle: 'italic',
          color: COLORS.inkSoft,
        }}
      >
        manna · a private morning page
      </div>
    </div>
  );
}
